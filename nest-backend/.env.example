# Server
# Port for the API (Railway/Heroku set this automatically)
PORT=3000
NODE_ENV=development

# Database
# Use DATABASE_URL for a single connection string (Railway, Heroku, etc.)
DATABASE_URL=postgresql://user:password@host:5432/database

# Or use individual DB_* variables:
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=nest_backend

# JWT - Required for authentication (Strapi-compatible: accepts 'sub' or 'id' in payload)
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# OpenAI - Optional; AI features (CDSS, Copilot, Predictive Medicine) return empty data when not set
OPENAI_API_KEY=
