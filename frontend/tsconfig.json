{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true
  },
  "include": [
    "hooks/useTelemedicineCall.ts",
    "lib/webrtc-connection-quality.ts",
    "lib/fetch-webrtc-ice-servers.ts",
    "lib/webrtc-recording-api.ts",
    "lib/send-webrtc-metrics.ts",
    "lib/heydoctor-trace-headers.ts",
    "lib/webrtc-transport-telemetry.ts",
    "lib/rtc-stats-report-get.ts",
    "lib/fetch-platform-global.ts",
    "lib/api-credentials.ts",
    "lib/heydoctor-api.ts",
    "lib/server/public-doctors.ts",
    "lib/api-doctors-register.ts",
    "lib/api-payments.ts",
    "components/PlatformAdminDashboard.tsx",
    "components/DoctorOnboardingForm.tsx",
    "components/ConsultationPaymentPanel.tsx",
    "components/WebrtcRecordingControls.tsx",
    "socket.io-client.d.ts"
  ]
}
