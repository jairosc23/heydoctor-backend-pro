{
  "kind": "collectionType",
  "collectionName": "patients",
  "info": {
    "singularName": "patient",
    "pluralName": "patients",
    "displayName": "patient",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "identification_type": {
      "type": "enumeration",
      "enum": [
        "passport",
        "id card",
        "rut"
      ]
    },
    "city": {
      "type": "string"
    },
    "province": {
      "type": "string"
    },
    "birth_date": {
      "type": "date",
      "required": true
    },
    "gender": {
      "type": "enumeration",
      "enum": [
        "M",
        "F",
        "Other"
      ]
    },
    "profile_picture": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "reviews_given": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::review.review",
      "mappedBy": "patient"
    },
    "clinical_record": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::clinical-record.clinical-record",
      "mappedBy": "patient"
    },
    "user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user",
      "mappedBy": "patient"
    },
    "uid": {
      "type": "uid"
    },
    "appointments": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::appointment.appointment",
      "mappedBy": "patient"
    },
    "firstname": {
      "type": "string",
      "required": true
    },
    "lastname": {
      "type": "string",
      "required": true
    },
    "identification": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "phone": {
      "type": "string"
    },
    "favorite_doctors": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::doctor.doctor"
    },
    "clinic": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::clinic.clinic",
      "inversedBy": "patients"
    }
  }
}
