    },
    "cie_10_code": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::cie-10-code.cie-10-code"
    },
    "clinical_record": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::clinical-record.clinical-record",
