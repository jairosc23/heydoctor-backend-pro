{
  "kind": "collectionType",
  "collectionName": "diagnostics",
  "info": {
    "singularName": "diagnostic",
    "pluralName": "diagnostics",
    "displayName": "diagnostic",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "doctor": {
      "type": "relation",
