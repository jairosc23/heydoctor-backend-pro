      "target": "api::doctor.doctor"
    },
    "patient": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::patient.patient"
    },
    "medications": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::medication.medication",
