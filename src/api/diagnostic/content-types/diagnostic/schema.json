    "diagnostic_date": {
      "type": "date",
      "required": true
    },
    "diagnosis_details": {
      "type": "text",
      "minLength": 20,
      "private": true
    },
    "clinic": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::clinic.clinic"
