{
  "kind": "collectionType",
  "collectionName": "appointments",
  "info": {
    "singularName": "appointment",
    "pluralName": "appointments",
    "displayName": "appointment",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "duration": {
      "type": "integer",
      "default": 45
    },
    "date": {
      "type": "datetime",
      "required": true
    },
    "specialty_profile": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::specialty-profile.specialty-profile",
      "inversedBy": "appointments"
    },
    "patient": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::patient.patient",
      "inversedBy": "appointments"
    },
    "doctor": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::doctor.doctor",
      "inversedBy": "appointments"
    },
    "clinical_record": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::clinical-record.clinical-record",
      "inversedBy": "appointments"
    },
    "videocall": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::videocall.videocall",
      "mappedBy": "appointment"
    },
    "payment": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::payment.payment",
      "mappedBy": "appointment"
    },
    "confirmed": {
      "type": "boolean",
      "default": false
    },
    "appointment_reason": {
      "type": "text"
    },
    "files": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "diagnostic": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::diagnostic.diagnostic",
      "mappedBy": "appointment"
    },
    "active": {
      "type": "boolean",
      "default": true
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "scheduled",
        "in_progress",
        "completed",
        "cancelled",
        "no_show"
      ],
      "default": "scheduled"
    }
  }
}
