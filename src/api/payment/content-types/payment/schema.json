{
  "kind": "collectionType",
  "collectionName": "payments",
  "info": {
    "singularName": "payment",
    "pluralName": "payments",
    "displayName": "payment",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "appointment": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::appointment.appointment",
      "inversedBy": "payment"
    },
    "amount": {
      "type": "decimal"
    },
    "timestamp": {
      "type": "date"
    },
    "order": {
      "type": "biginteger",
      "required": true,
      "unique": true
    },
    "status": {
      "type": "string",
      "required": true,
      "default": "pending"
    },
    "payment_data": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::payment-webhook.payment-webhook",
      "inversedBy": "payment"
    }
  }
}
