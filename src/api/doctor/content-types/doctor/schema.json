{
  "kind": "collectionType",
  "collectionName": "doctors",
  "info": {
    "singularName": "doctor",
    "pluralName": "doctors",
    "displayName": "doctor",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "doctor"
    },
    "specialty_profiles": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::specialty-profile.specialty-profile",
      "inversedBy": "doctors"
    },
    "signup_request": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::signup-request.signup-request",
      "mappedBy": "doctor"
    },
    "serviceCost": {
      "type": "biginteger",
      "default": "1",
      "required": true
    },
    "reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::review.review",
      "mappedBy": "doctor"
    },
    "agenda": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::agenda.agenda",
      "mappedBy": "doctor"
    },
    "appointments": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::appointment.appointment",
      "mappedBy": "doctor"
    },
    "services": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::service.service",
      "mappedBy": "doctor"
    },
    "non_validated_experience": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "profile_description": {
      "type": "text"
    },
    "registration_number": {
      "type": "string"
    },
    "registration_issuer": {
      "type": "string"
    },
    "country": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::country.country"
    },
    "stamp": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "signature": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "languages": {
      "displayName": "languages",
      "type": "component",
      "repeatable": true,
      "component": "profile.languages"
    },
    "validated_experience": {
      "displayName": "experience",
      "type": "component",
      "repeatable": true,
      "component": "profile.experience"
    },
    "service_settings": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::service-setting.service-setting",
      "mappedBy": "doctor"
    }
  }
}
