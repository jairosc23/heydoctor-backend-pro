    "reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::review.review",
      "mappedBy": "doctor"
    },
    "agenda": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::agenda.agenda",
      "mappedBy": "doctor"
