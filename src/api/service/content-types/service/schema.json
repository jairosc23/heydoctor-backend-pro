{
  "kind": "collectionType",
  "collectionName": "services",
  "info": {
    "singularName": "service",
    "pluralName": "services",
    "displayName": "service",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "doctor": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::doctor.doctor",
      "inversedBy": "services"
    },
    "specialty_profile": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::specialty-profile.specialty-profile",
      "inversedBy": "services"
    },
    "service_cost": {
      "type": "decimal"
    },
    "service_setting": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::service-setting.service-setting",
      "mappedBy": "service"
    },
    "description": {
      "type": "text"
    },
    "reason": {
      "type": "text"
    },
    "extra": {
      "type": "component",
      "repeatable": true,
      "component": "service.extra-rates"
    },
    "default": {
      "type": "boolean",
      "default": true,
      "required": true
