# ─────────────────────────────────────────────────────────
# HeyDoctor Backend — Environment Variables
# Copy to .env.local and fill in values
# ─────────────────────────────────────────────────────────

# ── CORE ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── DATABASE (required) ─────────────────────────────────
# Railway provides DATABASE_PUBLIC_URL; local dev uses DATABASE_URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/heydoctor
# DATABASE_PUBLIC_URL=  # Set by Railway automatically

# ── Magic link (emisión manual / servicio futuro) ───────
# JWT firmado con JWT_SECRET: payload { sub, email, role, typ: 'magic_link', jti: '<uuid>' }, expiresIn corto (p. ej. 15m).
# Canje: POST /api/auth/magic-link con body { "token": "..." }; un uso por `jti` o por token de acceso estándar (hash).

# ── AUTH (required) ──────────────────────────────────────
# Mismo valor para firmar tokens (login/refresh) y verificarlos (GET /auth/me).
# Railway: una variable JWT_SECRET por servicio; sin comillas extra en el valor.
# Generar: openssl rand -hex 32
JWT_SECRET=change-this-to-a-secure-random-string
# TTL access JWT y refresh (formato 15m, 7d, 3600s)
# JWT_ACCESS_TTL=15m
# JWT_REFRESH_TTL=7d
# Sesiones refresh activas por usuario (5–20; por defecto 8). Al superarse se revocan las más antiguas.
# AUTH_MAX_ACTIVE_REFRESH_SESSIONS=8
# POST /api/auth/revoke-all por minuto por usuario (3–10; por defecto 5).
# AUTH_REVOKE_ALL_PER_MINUTE=5
# true = Logger.debug con claims del payload al entrar en validate() (sub/email/role)
JWT_DEBUG=false
# 1 = segundo res.cookie(heydoctor_session) al final de POST /api/auth/login (solo depuración proxies)
# AUTH_DEBUG_RESEND_SESSION_COOKIE=1

# ── CORS ─────────────────────────────────────────────────
# Solo aplica en desarrollo (no producción: origen fijado a heydoctor-frontend.vercel.app en main.ts).
# Ejemplo: http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# ── REDIS (optional) ─────────────────────────────────────
# Shared JWT validation cache, Nest cache manager, and rate-limit storage across instances
# Example: redis://default:password@host:6379
REDIS_URL=

# ── PAYKU (payment provider) ────────────────────────────
PAYKU_API_URL=https://app.payku.cl/api
PAYKU_API_KEY=
PAYKU_WEBHOOK_SECRET=
PAYKU_WEBHOOK_BEARER=
# Allow webhook without auth in local dev (never in production)
PAYKU_WEBHOOK_ALLOW_UNSAFE_LOCAL=false
# Payment amount in CLP (default: 15000)
CONSULTATION_PAYMENT_AMOUNT_CLP=15000
# Minutes before pending payment expires (default: 1440 = 24h)
PAYMENT_PENDING_EXPIRE_MINUTES=1440

# ── WebRTC / TURN (multi-región LATAM; mismo secreto en todos los nodos coturn) ──
# Credenciales efímeras estilo coturn REST (HMAC-SHA1): username = expiry:userId, password = base64(hmac)
TURN_REST_SECRET=
# TTL en segundos para el campo expiry (por defecto 86400)
# TURN_CREDENTIAL_TTL_SEC=86400
# Lista separada por comas; por defecto turn-scl/gru/bog.heydoctor.health
# TURN_REGIONAL_HOSTS=turn-scl.heydoctor.health,turn-gru.heydoctor.health,turn-bog.heydoctor.health
# Si TURN_REST_SECRET está vacío, credenciales estáticas (misma user/pass en cada host):
# TURN_HEYDOCTOR_USERNAME=
# TURN_HEYDOCTOR_CREDENTIAL=

# ── OPENAI (AI features) ────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── COMPLIANCE ───────────────────────────────────────────
# Enable HIPAA-mode: stricter logging, shorter sessions
HIPAA_MODE=false

# ── Encryption / KMS (roadmap: grabaciones S3 + datos sensibles) ──
# AWS_REGION=
# RECORDINGS_KMS_KEY_ARN=  # CMK para SSE-KMS en bucket de grabaciones
# RECORDINGS_S3_BUCKET=
# Optional: application-level field encryption (clave RAW nunca en repo; solo en vault)
# PHI_FIELD_ENCRYPTION_KEY=

# ── URLS ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_PUBLIC_URL=http://localhost:3001
