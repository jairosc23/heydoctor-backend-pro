# ─────────────────────────────────────────────────────────
# HeyDoctor Backend — Environment Variables
# Copy to .env.local and fill in values
# ─────────────────────────────────────────────────────────

# ── CORE ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── DATABASE (required) ─────────────────────────────────
# Railway provides DATABASE_PUBLIC_URL; local dev uses DATABASE_URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/heydoctor
# DATABASE_PUBLIC_URL=  # Set by Railway automatically

# ── AUTH (required) ──────────────────────────────────────
# Mismo valor para firmar tokens (login/refresh) y verificarlos (GET /auth/me).
# Railway: una variable JWT_SECRET por servicio; sin comillas extra en el valor.
# Generar: openssl rand -hex 32
JWT_SECRET=change-this-to-a-secure-random-string
# TTL access JWT y refresh (formato 15m, 7d, 3600s)
# JWT_ACCESS_TTL=15m
# JWT_REFRESH_TTL=7d
# true = Logger.debug con claims del payload al entrar en validate() (sub/email/role)
JWT_DEBUG=false

# ── CORS ─────────────────────────────────────────────────
# Comma-separated browser origins. If unset, defaults to http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# ── REDIS (optional) ─────────────────────────────────────
# Shared JWT validation cache, Nest cache manager, and rate-limit storage across instances
# Example: redis://default:password@host:6379
REDIS_URL=

# ── PAYKU (payment provider) ────────────────────────────
PAYKU_API_URL=https://app.payku.cl/api
PAYKU_API_KEY=
PAYKU_WEBHOOK_SECRET=
PAYKU_WEBHOOK_BEARER=
# Allow webhook without auth in local dev (never in production)
PAYKU_WEBHOOK_ALLOW_UNSAFE_LOCAL=false
# Payment amount in CLP (default: 15000)
CONSULTATION_PAYMENT_AMOUNT_CLP=15000
# Minutes before pending payment expires (default: 1440 = 24h)
PAYMENT_PENDING_EXPIRE_MINUTES=1440

# ── OPENAI (AI features) ────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── COMPLIANCE ───────────────────────────────────────────
# Enable HIPAA-mode: stricter logging, shorter sessions
HIPAA_MODE=false

# ── URLS ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_PUBLIC_URL=http://localhost:3001
