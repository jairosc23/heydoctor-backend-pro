# Server
HOST=0.0.0.0
PORT=1337
NODE_ENV=development

# Security keys (generate unique values for production)
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
JWT_SECRET=tobemodified

# Database (PostgreSQL)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=heydoctor
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=
DATABASE_SSL=false

# Cloudinary (file uploads)
CLOUDINARY_NAME=
CLOUDINARY_KEY=
CLOUDINARY_SECRET=

# Payku (payment gateway)
PAYKU_URL=
PAYKU_TKPUB=

# Redis (WebSocket scaling - required in production)
REDIS_URL=

# CORS origins (comma-separated, used by middlewares and WebSocket)
CORS_ORIGINS=https://heydoctor.health,https://www.heydoctor.health
