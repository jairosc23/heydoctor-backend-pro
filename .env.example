# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/heydoctor

# JWT signing secret (use a long random string in production)
JWT_SECRET=change-this-to-a-secure-random-string-in-production

# Optional: access token TTL in seconds (default: 604800 = 7 days)
# JWT_EXPIRES_IN=604800

# HTTP port
PORT=3001

# Set to production to disable TypeORM synchronize (use migrations instead)
NODE_ENV=development
