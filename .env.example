# Server
HOST=0.0.0.0
PORT=1337
NODE_ENV=development
# URL pública (Railway/producción). Ej: https://api.heydoctor.health
PUBLIC_URL=

# Security keys - generate with: openssl rand -base64 32
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
JWT_SECRET=tobemodified

# Database (PostgreSQL)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=heydoctor
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=
DATABASE_SSL=false
# Pool: max=20, idleTimeout=30s, connectionTimeout=10s
# DATABASE_POOL_MAX=20
# DATABASE_POOL_IDLE_TIMEOUT=30000
# DATABASE_POOL_CONNECT_TIMEOUT=10000
# DATABASE_CONNECTION_TIMEOUT=10000
# Read replica (opcional): SELECT usa replica, INSERT/UPDATE/DELETE usa primary
# DATABASE_READ_HOST=
# DATABASE_READ_PORT=5432
# DATABASE_READ_NAME=heydoctor
# DATABASE_READ_USERNAME=postgres
# DATABASE_READ_PASSWORD=
# DATABASE_READ_POOL_MAX=10
# Full connection string (used by backup scripts)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/heydoctor

# File encryption at rest (AES-256-GCM)
# Cuando está definido: archivos clínicos se cifran antes de subir a Cloudinary y se descifran al descargar.
# Generar clave: openssl rand -hex 32 (debe ser exactamente 64 caracteres hex)
# Sin definir: archivos se guardan sin cifrado (comportamiento actual)
# FILE_ENCRYPTION_KEY=

# Cloudinary (file uploads)
CLOUDINARY_NAME=
CLOUDINARY_KEY=
CLOUDINARY_SECRET=

# Payku (payment gateway)
PAYKU_URL=
PAYKU_TKPUB=
# IPs permitidas para webhook (comma-separated). Vacío = aceptar todas.
# PAYKU_WEBHOOK_IPS=1.2.3.4,5.6.7.8

# Redis (WebSocket scaling + cache - required in production)
REDIS_URL=
REDIS_CACHE_TTL=300

# WebRTC TURN - OBLIGATORIO en producción para videollamadas en redes restrictivas.
# El frontend usa /api/webrtc/ice-servers como fuente principal de ICE.
#
# Twilio (global.turn.twilio.com):
TURN_USERNAME=
TURN_PASSWORD=
#
# turn.heydoctor.health (coturn propio). Nota: Strapi usa TURN_PASSWORD; Next.js usa TURN_CREDENTIAL.
TURN_HEYDOCTOR_USERNAME=
TURN_HEYDOCTOR_CREDENTIAL=

# CORS origins (comma-separated, used by middlewares and WebSocket)
CORS_ORIGINS=https://heydoctor.health,https://www.heydoctor.health

# doctor-applications: permiso create se asigna automáticamente al rol Public en bootstrap

# ClickHouse (analytics / data warehouse)
# Sin CLICKHOUSE_URL: analytics desactivado
# CLICKHOUSE_URL=http://localhost:8123
# CLICKHOUSE_DATABASE=heydoctor

# Meilisearch (búsqueda avanzada)
# Sin MEILI_HOST: búsqueda usa fallback SQL
# MEILI_HOST=http://localhost:7700
# MEILI_API_KEY=

# Sentry error monitoring
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# Database backup (S3-compatible storage)
# BACKUP_BUCKET=heydoctor-backups
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_ENDPOINT_URL=
# BACKUP_RETENTION_DAYS=30
